---
import SeoLayout from '../../layouts/SeoLayout.astro';

const canonicalUrl = new URL('/schemes/', Astro.site || 'https://www.meralabh.com').toString();
const pageTitle = 'Government Schemes in India | MeraLabh';
const pageDescription =
  'Browse MeraLabh scheme guides and tools in one place. Explore eligibility rules, documents, benefits, and online check pages for Indian government schemes.';

const schemeCards = [
  {
    title: 'Ayushman Bharat PM-JAY',
    description:
      'Explore the full eligibility guide, key exclusions, documents needed, and the online check tool for Ayushman Card.',
    guideUrl: '/',
    toolUrl: '/check/',
  },
];

const pageSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  publisher: {
    '@type': 'Organization',
    name: 'MeraLabh',
    url: 'https://www.meralabh.com/',
  },
});

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://www.meralabh.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Government Schemes',
      item: canonicalUrl,
    },
  ],
});
---
<SeoLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  schemas={[pageSchema, breadcrumbSchema]}
  activeNav="schemes"
>
  <section class="hero-section">
    <div class="hero-container">
      <h1 class="hero-title">Government Schemes Hub</h1>
      <p class="hero-description">Browse MeraLabh's scheme guides and useful tools from one central page as we expand coverage across Indian government benefits.</p>
    </div>
  </section>

  <div class="main-wrapper">
    <nav class="breadcrumb-nav" aria-label="Breadcrumb">
      <ol class="breadcrumb-list">
        <li><a href="/">Home</a></li>
        <li><span class="breadcrumb-separator">›</span></li>
        <li class="active" aria-current="page">Government Schemes</li>
      </ol>
    </nav>

    <main class="content-area" style="max-width: 1100px; margin: 0 auto;">
      <section class="editorial-section">
        <h2>Explore Scheme Guides</h2>
        <p>Find simple, easy-to-understand guides for major government benefits. Learn if you qualify, what documents you need, and how to apply step-by-step.</p>
      </section>

      <section class="editorial-section">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
          {schemeCards.map((scheme) => (
            <article style="background: #fff; border: 1px solid rgba(14, 78, 162, 0.12); border-radius: 18px; padding: 1.5rem; box-shadow: 0 18px 40px rgba(14, 78, 162, 0.08);">
              <h3 style="margin-bottom: 0.65rem; font-size: 1.25rem; color: var(--primary-blue);">{scheme.title}</h3>
              <p style="margin-bottom: 1rem; color: var(--text-secondary);">{scheme.description}</p>
              <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
                <a href={scheme.guideUrl} class="btn btn-secondary">Read Guide</a>
                <a href={scheme.toolUrl} class="btn btn-primary">Use Tool</a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="editorial-section">
        <h2>More Schemes Coming Soon</h2>
        <p>We are constantly adding new central and state government schemes to our portal. Check back soon for guides on pension, education, and housing schemes.</p>
      </section>
    </main>
  </div>
</SeoLayout>
