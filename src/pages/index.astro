---
import SeoLayout from '../layouts/SeoLayout.astro';

const canonicalUrl = new URL('/', Astro.site || 'https://www.meralabh.com').toString();
const faqItems = [
  {
    question: 'How can I check my name in the official PMJAY list?',
    answer:
      'You can check your name on the official portal by using the Am I Eligible option with your mobile number, ration card number, HHD number, or name. You can also visit a Common Service Centre or empaneled hospital helpdesk.',
  },
  {
    question: 'Is there an income limit for Ayushman Bharat eligibility?',
    answer:
      'The scheme targets low-income and vulnerable households. Rural families must match SECC deprivation criteria, while urban households must fall into approved informal worker categories. Government employees and income-tax payers are excluded.',
  },
  {
    question: 'Can I apply for an Ayushman Card if I own a motorcycle?',
    answer:
      'Motorized vehicle ownership is generally treated as an exclusion signal under PM-JAY eligibility rules, so many households with a motorcycle will not qualify.',
  },
  {
    question: 'Is the PMJAY cover per person or per family?',
    answer:
      'The health cover is a family-floater benefit. The annual amount can be used by one member or shared across family members during the year.',
  },
];

const pageSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Ayushman Card Eligibility Criteria 2026 - Who is Eligible for PM-JAY?',
  description:
    'Understand the detailed eligibility criteria for the Ayushman Bharat PMJAY scheme. Discover who is eligible under rural and urban rules, exclusions, and required documents.',
  url: canonicalUrl,
  about: {
    '@type': 'GovernmentService',
    name: 'Ayushman Bharat PM-JAY',
  },
  publisher: {
    '@type': 'Organization',
    name: 'MeraLabh',
    url: 'https://www.meralabh.com/',
  },
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
});
---
<SeoLayout
  title="Ayushman Card Eligibility Criteria 2026 - Who is Eligible for PM-JAY?"
  description="Understand the detailed eligibility criteria for the Ayushman Bharat PMJAY scheme. Discover who is eligible under rural and urban rules, exclusions, and required documents."
  canonicalUrl={canonicalUrl}
  schemaMarkup={pageSchema}
  breadcrumbListSchema={faqSchema}
  activeNav="home"
>
  <section class="hero-section">
    <div class="hero-container">
      <h1 class="hero-title">Ayushman Bharat PMJAY Eligibility Criteria 2026</h1>
      <p class="hero-description">Find out if you qualify for India's largest government-funded healthcare program providing Rs 5 lakh annual cashless health cover per family.</p>
      <div class="trust-bar">
        <div class="trust-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          <span>Fact-checked and verified for 2026</span>
        </div>
      </div>
    </div>
  </section>

  <div class="main-wrapper">
    <nav class="breadcrumb-nav" aria-label="Breadcrumb">
      <ol class="breadcrumb-list">
        <li><a href="/">Home</a></li>
        <li><span class="breadcrumb-separator">›</span></li>
        <li><a href="/">Healthcare Schemes</a></li>
        <li><span class="breadcrumb-separator">›</span></li>
        <li class="active" aria-current="page">Ayushman Bharat Eligibility Rules 2026</li>
      </ol>
    </nav>

    <div class="split-layout">
      <aside class="toc-sidebar" aria-label="Table of Contents">
        <h3 class="toc-title">ON THIS PAGE</h3>
        <ul class="toc-list">
          <li><a href="#about" class="toc-item-link active">What is PMJAY Scheme?</a></li>
          <li><a href="#rural-rules" class="toc-item-link">Rural Eligibility Rules</a></li>
          <li><a href="#urban-rules" class="toc-item-link">Urban Occupation List</a></li>
          <li><a href="#exclusions" class="toc-item-link">Who is Excluded?</a></li>
          <li><a href="#senior-citizens" class="toc-item-link">Senior Citizens (70+)</a></li>
          <li><a href="#documents" class="toc-item-link">Required Documents</a></li>
          <li><a href="#faq" class="toc-item-link">Frequently Asked Questions</a></li>
        </ul>
      </aside>

      <main class="content-area">
        <section id="about" class="editorial-section section-anchor">
          <h2>What is the Ayushman Bharat PM-JAY Scheme?</h2>
          <p>Pradhan Mantri Jan Arogya Yojana (PM-JAY) is the flagship national health insurance scheme of the Government of India. It provides cashless and paperless secondary and tertiary healthcare treatment for poor, vulnerable, and deprived families.</p>
          <p>Eligible families get a health cover of <strong>Rs 5 lakh per family per year</strong> for treatment at empaneled government and private hospitals across India. There is no limit on family size, age, or gender under the scheme.</p>
          <div style="background-color: #f0fdf4; border-left: 4px solid var(--secondary-green); padding: 1.5rem; border-radius: 6px; margin: 1.5rem 0;">
            <h4 style="font-weight: 700; color: #047857; margin-bottom: 0.5rem; font-size: 1.1rem;">Quick checker tool available</h4>
            <p style="margin-bottom: 0; font-size: 0.95rem;">Skip the long reading if you are in a hurry and use our step-by-step evaluator to check eligibility online.</p>
            <a href="/check/" class="btn btn-primary" style="margin-top: 1rem; padding: 0.5rem 1.2rem; font-size: 0.9rem;">Start Eligibility Check</a>
          </div>
        </section>

        <section id="rural-rules" class="editorial-section section-anchor">
          <h2>Rural Eligibility Criteria</h2>
          <p>In rural areas, eligibility is primarily based on housing, landownership, and deprivation categories recorded in the Socio-Economic Caste Census (SECC 2011). Families falling under any of the following deprivation categories are eligible:</p>
          <div class="eligibility-table-wrapper">
            <table class="eligibility-table">
              <thead>
                <tr>
                  <th>Deprivation code</th>
                  <th>Deprivation category description</th>
                  <th>Eligibility status</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>D1</td>
                  <td>Only one room with kucha walls and kucha roof.</td>
                  <td><span class="status-badge eligible">Eligible</span></td>
                </tr>
                <tr>
                  <td>D2</td>
                  <td>No adult member between the ages of 16 and 59 inside the household.</td>
                  <td><span class="status-badge eligible">Eligible</span></td>
                </tr>
                <tr>
                  <td>D3</td>
                  <td>Female-headed households with no adult male member between 16 and 59.</td>
                  <td><span class="status-badge eligible">Eligible</span></td>
                </tr>
                <tr>
                  <td>D4</td>
                  <td>Disabled member inside the household and no able-bodied adult member.</td>
                  <td><span class="status-badge eligible">Eligible</span></td>
                </tr>
                <tr>
                  <td>D5</td>
                  <td>Scheduled Caste and Scheduled Tribe rural households.</td>
                  <td><span class="status-badge eligible">Eligible</span></td>
                </tr>
                <tr>
                  <td>D7</td>
                  <td>Landless households deriving a major part of their income from manual casual labor.</td>
                  <td><span class="status-badge eligible">Eligible</span></td>
                </tr>
              </tbody>
            </table>
          </div>
          <p>Additionally, rural families living in destitution, manual scavengers, primitive tribal groups, and legally released bonded laborers are treated as eligible without needing deprivation checks.</p>
        </section>

        <section id="urban-rules" class="editorial-section section-anchor">
          <h2>Urban Eligibility: Approved Occupational Categories</h2>
          <p>In urban areas, eligibility is based on the specific occupation of household members. The scheme lists broad informal and casual worker categories that qualify:</p>
          <ul style="margin-left: 1.5rem; margin-bottom: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; font-size: 1rem; color: var(--text-secondary);">
            <li>Ragpickers and street sweepers</li>
            <li>Beggars and those surviving on alms</li>
            <li>Domestic workers and home-based helpers</li>
            <li>Street vendors, hawkers, cobblers, and vegetable sellers</li>
            <li>Construction workers, plumbers, masons, painters, and welders</li>
            <li>Security guards, coolies, and other loaders</li>
            <li>Sweepers, sanitation workers, and gardeners</li>
            <li>Home-based artisans, tailors, weavers, and handicraft workers</li>
            <li>Transport workers, drivers, conductors, cart pullers, and rickshaw pullers</li>
            <li>Shop workers, assistants, peons, delivery workers, and waiters</li>
            <li>Washermen and mechanics</li>
          </ul>
        </section>

        <section id="exclusions" class="editorial-section section-anchor">
          <h2>Who is Excluded from Ayushman Bharat?</h2>
          <p>Even if you fit some of the criteria above, a household will be excluded if it meets any of the following parameters:</p>
          <div class="eligibility-table-wrapper">
            <table class="eligibility-table">
              <thead>
                <tr>
                  <th>Exclusion parameter</th>
                  <th>Description</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Motorized vehicles</td>
                  <td>Owns a motorized two-wheeler, three-wheeler, four-wheeler, or fishing boat.</td>
                  <td><span class="status-badge excluded">Excluded</span></td>
                </tr>
                <tr>
                  <td>Mechanized agri equipment</td>
                  <td>Owns mechanized agricultural equipment like tractors or harvesters.</td>
                  <td><span class="status-badge excluded">Excluded</span></td>
                </tr>
                <tr>
                  <td>KCC limit</td>
                  <td>Holds a Kisan Credit Card with a credit limit exceeding Rs 50,000.</td>
                  <td><span class="status-badge excluded">Excluded</span></td>
                </tr>
                <tr>
                  <td>Government employment</td>
                  <td>Any member of the household is a regular, permanent government employee.</td>
                  <td><span class="status-badge excluded">Excluded</span></td>
                </tr>
                <tr>
                  <td>Income tax payers</td>
                  <td>Any member of the family pays income tax or professional tax.</td>
                  <td><span class="status-badge excluded">Excluded</span></td>
                </tr>
                <tr>
                  <td>High landholding</td>
                  <td>Owns more than 5 acres of irrigated agricultural land or 7.5 acres of dry land.</td>
                  <td><span class="status-badge excluded">Excluded</span></td>
                </tr>
                <tr>
                  <td>Air conditioning and appliances</td>
                  <td>Owns a refrigerator, air conditioner, or landline phone.</td>
                  <td><span class="status-badge excluded">Excluded</span></td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section id="senior-citizens" class="editorial-section section-anchor">
          <h2>Eligibility for Senior Citizens (70 Years and Above)</h2>
          <p>After the late-2024 expansion, all senior citizens aged 70 years and above are eligible for Ayushman Bharat PM-JAY health cover regardless of their socio-economic status.</p>
          <p>Key highlights:</p>
          <ul style="margin-left: 1.5rem; margin-bottom: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; font-size: 1rem; color: var(--text-secondary);">
            <li>Senior citizens aged 70+ receive a distinct Ayushman Card.</li>
            <li>They get an exclusive top-up cover of <strong>Rs 5 lakh per year</strong> shared among the seniors in the family.</li>
            <li>Seniors already covered under another public health insurance scheme may choose whether to stay with it or opt into PM-JAY.</li>
          </ul>
        </section>

        <section id="documents" class="editorial-section section-anchor">
          <h2>Required Documents for Ayushman Card Registration</h2>
          <p>To register or check your name in the PMJAY beneficiary list, keep the following documents ready for verification:</p>
          <ul style="margin-left: 1.5rem; display: flex; flex-direction: column; gap: 0.8rem; font-size: 1rem; color: var(--text-secondary);">
            <li><strong><a href="/check/">Aadhaar Card</a>:</strong> Primary document required for identity and biometric e-KYC verification.</li>
            <li><strong><a href="#rural-rules">Ration Card (NFSA)</a>:</strong> Essential proof for validating household and family member count.</li>
            <li><strong>Active mobile number:</strong> Required for OTP authentication on the official portal.</li>
            <li><strong>Address proof:</strong> Useful if your current address differs from your Aadhaar record.</li>
            <li><strong>Caste certificate:</strong> Required if claiming eligibility under SC or ST rural categories.</li>
          </ul>
        </section>
      </main>
    </div>
  </div>

  <section class="faq-section id-anchor" id="faq">
    <h2 class="faq-title">Frequently Asked Questions</h2>
    <div class="faq-container">
      {faqItems.map((item) => (
        <div class="faq-card">
          <div class="faq-question">
            <span>{item.question}</span>
            <svg class="faq-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
          <div class="faq-answer">
            <p>{item.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <script is:inline>
    const faqCards = document.querySelectorAll('.faq-card');
    faqCards.forEach((card) => {
      const question = card.querySelector('.faq-question');
      question?.addEventListener('click', () => {
        const isOpen = card.classList.contains('open');
        faqCards.forEach((faqCard) => faqCard.classList.remove('open'));
        if (!isOpen) {
          card.classList.add('open');
        }
      });
    });

    const sections = document.querySelectorAll('.section-anchor');
    const tocLinks = document.querySelectorAll('.toc-item-link');

    window.addEventListener('scroll', () => {
      let currentSectionId = '';
      sections.forEach((section) => {
        if (window.scrollY >= section.offsetTop - 120) {
          currentSectionId = section.getAttribute('id') ?? '';
        }
      });

      tocLinks.forEach((link) => {
        link.classList.remove('active');
        if (link.getAttribute('href') === `#${currentSectionId}`) {
          link.classList.add('active');
        }
      });
    });
  </script>
</SeoLayout>
