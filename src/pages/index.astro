---
import SeoLayout from '../layouts/SeoLayout.astro';

const canonicalUrl = new URL('/', Astro.site || 'https://www.meralabh.com').toString();
const pageTitle = 'Ayushman Card Eligibility Criteria 2026 | MeraLabh';
const pageDescription =
  'Understand the detailed eligibility criteria for the Ayushman Bharat PMJAY scheme. Discover who is eligible under rural and urban rules, exclusions, and required documents.';
const faqItems = [
  {
    question: 'How can I check my name in the official PMJAY list?',
    answer:
      'You can check your name on the official portal by using the Am I Eligible option with your mobile number, ration card number, HHD number, or name. You can also visit a Common Service Centre or empaneled hospital helpdesk.',
  },
  {
    question: 'Is there an income limit for Ayushman Bharat eligibility?',
    answer:
      'The scheme targets low-income and vulnerable households. Rural families must match SECC deprivation criteria, while urban households must fall into approved informal worker categories. Government employees and income-tax payers are excluded.',
  },
  {
    question: 'Can I apply for an Ayushman Card if I own a motorcycle?',
    answer:
      'Motorized vehicle ownership is generally treated as an exclusion signal under PM-JAY eligibility rules, so many households with a motorcycle will not qualify.',
  },
  {
    question: 'Is the PMJAY cover per person or per family?',
    answer:
      'The health cover is a family-floater benefit. The annual amount can be used by one member or shared across family members during the year.',
  },
];

const pageSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  about: {
    '@type': 'GovernmentService',
    name: 'Ayushman Bharat PM-JAY',
  },
  publisher: {
    '@type': 'Organization',
    name: 'MeraLabh',
    url: 'https://www.meralabh.com/',
  },
});

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: canonicalUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Ayushman Bharat Eligibility Rules 2026',
      item: canonicalUrl,
    },
  ],
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
});
---
<SeoLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  schemas={[pageSchema, breadcrumbSchema, faqSchema]}
  activeNav="home"
>
  <section class="hero-section">
    <div class="hero-container">
      <h1 class="hero-title">Ayushman Bharat PMJAY Eligibility Criteria 2026</h1>
      <p class="hero-description">Find out if you qualify for India's largest government-funded healthcare program providing Rs 5 lakh annual cashless health cover per family.</p>
        <div class="trust-bar">
          <div class="trust-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <span>Fact-checked and verified for 2026</span>
          </div>
        </div>
        <p style="margin-top: 1rem; color: rgba(255, 255, 255, 0.82); font-size: 0.98rem;">
          Looking for other benefits too? Browse the growing <a href="/schemes/" style="color: #fff; font-weight: 700; text-decoration: underline;">government schemes hub</a>.
        </p>
      </div>
    </section>

  <div class="main-wrapper">
    <nav class="breadcrumb-nav" aria-label="Breadcrumb">
      <ol class="breadcrumb-list">
        <li><a href="/">Home</a></li>
        <li><span class="breadcrumb-separator">›</span></li>
        <li><a href="/schemes/">Government Schemes</a></li>
        <li><span class="breadcrumb-separator">›</span></li>
        <li class="active" aria-current="page">Ayushman Bharat Eligibility Rules 2026</li>
      </ol>
    </nav>

    <div class="split-layout">
      <aside class="toc-sidebar" aria-label="Table of Contents">
        <h3 class="toc-title">ON THIS PAGE</h3>
        <ul class="toc-list">
          <li><a href="#about" class="toc-item-link active">What is PMJAY Scheme?</a></li>
          <li><a href="#rural-rules" class="toc-item-link">Rural Eligibility Rules</a></li>
          <li><a href="#urban-rules" class="toc-item-link">Urban Occupation List</a></li>
          <li><a href="#exclusions" class="toc-item-link">Who is Excluded?</a></li>
          <li><a href="#senior-citizens" class="toc-item-link">Senior Citizens (70+)</a></li>
          <li><a href="#documents" class="toc-item-link">Required Documents</a></li>
          <li><a href="#faq" class="toc-item-link">Frequently Asked Questions</a></li>
        </ul>
      </aside>

      <main class="content-area">
        <section id="about" class="editorial-section section-anchor">
          <h2>What is the Ayushman Bharat PM-JAY Scheme?</h2>
          <p>Pradhan Mantri Jan Arogya Yojana (PM-JAY) is a national health insurance scheme by the Government of India. It offers free, cashless medical treatment of up to <strong>₹5 lakh per family per year</strong> at registered government and private hospitals. The scheme is designed to protect low-income families from high healthcare expenses, and there is no limit on family size, age, or gender.</p>
          <div style="background-color: #f0fdf4; border-left: 4px solid var(--secondary-green); padding: 1.5rem; border-radius: 6px; margin: 1.5rem 0;">
            <h4 style="font-weight: 700; color: #047857; margin-bottom: 0.5rem; font-size: 1.1rem;">Quick Checker Tool</h4>
            <p style="margin-bottom: 0; font-size: 0.95rem;">Want a quick answer? Use our interactive checker tool to see if your family is eligible in under 2 minutes.</p>
            <a href="/check/" class="btn btn-primary" style="margin-top: 1rem; padding: 0.5rem 1.2rem; font-size: 0.9rem;">Start Eligibility Check</a>
          </div>
        </section>

        <section id="rural-rules" class="editorial-section section-anchor">
          <h2>Rural Eligibility Rules</h2>
          <p>In rural areas, eligibility is based on your family's housing, income source, and household situation. You qualify if your household meets any of the following conditions:</p>
          <div class="eligibility-table-wrapper">
            <table class="eligibility-table">
              <thead>
                <tr>
                  <th>Official Code</th>
                  <th>Household Situation / Condition</th>
                  <th>Eligibility Status</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>D1</td>
                  <td>Families living in a temporary, single-room house (kucha walls and roof).</td>
                  <td><span class="status-badge eligible">Eligible</span></td>
                </tr>
                <tr>
                  <td>D2</td>
                  <td>Families with no working-age adults (no members aged 16 to 59).</td>
                  <td><span class="status-badge eligible">Eligible</span></td>
                </tr>
                <tr>
                  <td>D3</td>
                  <td>Homes run by women, with no adult male member aged 16 to 59.</td>
                  <td><span class="status-badge eligible">Eligible</span></td>
                </tr>
                <tr>
                  <td>D4</td>
                  <td>Families with a disabled member and no fit adult to support them.</td>
                  <td><span class="status-badge eligible">Eligible</span></td>
                </tr>
                <tr>
                  <td>D5</td>
                  <td>Scheduled Caste (SC) or Scheduled Tribe (ST) households.</td>
                  <td><span class="status-badge eligible">Eligible</span></td>
                </tr>
                <tr>
                  <td>D7</td>
                  <td>Families with no land who earn their living mostly from manual daily-wage labor.</td>
                  <td><span class="status-badge eligible">Eligible</span></td>
                </tr>
              </tbody>
            </table>
          </div>
          <p>Additionally, families living in extreme poverty, manual scavengers, primitive tribal groups, and legally released bonded laborers are automatically eligible.</p>
        </section>

        <section id="urban-rules" class="editorial-section section-anchor">
          <h2>Urban Eligibility: Eligible Occupations</h2>
          <p>In cities and towns (urban areas), eligibility is based on the type of work you do. If the main earner of your family works in any of these informal jobs, you qualify:</p>
          <ul style="margin-left: 1.5rem; margin-bottom: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; font-size: 1rem; color: var(--text-secondary);">
            <li>Ragpickers, sweepers, and sanitation workers</li>
            <li>Beggars or those surviving on charity</li>
            <li>Domestic workers (maids, cooks, and home helpers)</li>
            <li>Street vendors, hawkers, cobblers, and fruit/vegetable sellers</li>
            <li>Construction workers, plumbers, masons, painters, and welders</li>
            <li>Security guards, coolies, loaders, and manual helpers</li>
            <li>Gardeners and sweepers</li>
            <li>Artisans, tailors, weavers, and handicraft makers working from home</li>
            <li>Drivers, conductors, rickshaw pullers, and cart pullers</li>
            <li>Shop workers, delivery helpers, waiters, and peons</li>
            <li>Washermen (dhobis) and mechanics</li>
          </ul>
        </section>

        <section id="exclusions" class="editorial-section section-anchor">
          <h2>Who is Disqualified (Exclusions)?</h2>
          <p><strong>Important:</strong> Even if your family meets the rural or urban conditions, you will not qualify for the scheme if you meet any of these disqualification (exclusion) rules:</p>
          <div class="eligibility-table-wrapper">
            <table class="eligibility-table">
              <thead>
                <tr>
                  <th>Disqualification Rule</th>
                  <th>Description</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Motorized vehicles</td>
                  <td>Owning a motorized vehicle (like a motorcycle, scooter, car, auto-rickshaw, or motorboat).</td>
                  <td><span class="status-badge excluded">Excluded</span></td>
                </tr>
                <tr>
                  <td>Farming machinery</td>
                  <td>Owning farming machinery like tractors or harvesters.</td>
                  <td><span class="status-badge excluded">Excluded</span></td>
                </tr>
                <tr>
                  <td>Kisan Credit Card (KCC) limit</td>
                  <td>Having a Kisan Credit Card (KCC) with a limit of more than ₹50,000.</td>
                  <td><span class="status-badge excluded">Excluded</span></td>
                </tr>
                <tr>
                  <td>Government job</td>
                  <td>Having any family member working in a permanent government job.</td>
                  <td><span class="status-badge excluded">Excluded</span></td>
                </tr>
                <tr>
                  <td>Tax payers</td>
                  <td>Having any family member who pays income tax or professional tax.</td>
                  <td><span class="status-badge excluded">Excluded</span></td>
                </tr>
                <tr>
                  <td>Large landholding</td>
                  <td>Owning more than 5 acres of irrigated farmland, or over 7.5 acres of dry land.</td>
                  <td><span class="status-badge excluded">Excluded</span></td>
                </tr>
                <tr>
                  <td>Home appliances</td>
                  <td>Having a refrigerator, an air conditioner, or a landline phone at home.</td>
                  <td><span class="status-badge excluded">Excluded</span></td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section id="senior-citizens" class="editorial-section section-anchor">
          <h2>Eligibility for Senior Citizens (70 Years and Above)</h2>
          <p>All senior citizens aged 70 years and above are eligible for Ayushman Bharat PM-JAY health cover, regardless of their family income, land, or assets.</p>
          <p>Key things to know:</p>
          <ul style="margin-left: 1.5rem; margin-bottom: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; font-size: 1rem; color: var(--text-secondary);">
            <li>Every senior citizen aged 70+ gets a separate, dedicated Ayushman Card.</li>
            <li>They get a free health cover of <strong>₹5 lakh per year</strong>, which is shared among the senior members of the family.</li>
            <li>Seniors who already have other government health schemes (like CGHS or ECHS) can choose to either keep their existing scheme or switch to Ayushman Bharat.</li>
          </ul>
        </section>

        <section id="documents" class="editorial-section section-anchor">
          <h2>Required Documents for Ayushman Card</h2>
          <p>To register or check your name in the official beneficiary list, keep the following documents ready:</p>
          <ul style="margin-left: 1.5rem; display: flex; flex-direction: column; gap: 0.8rem; font-size: 1rem; color: var(--text-secondary);">
            <li><strong><a href="/check/">Aadhaar Card</a>:</strong> Used to verify your identity and biometrics (fingerprint or face scan).</li>
            <li><strong><a href="#rural-rules">Ration Card</a>:</strong> Needed to verify the members of your family.</li>
            <li><strong>Active mobile number:</strong> To receive OTP verification codes on the official portal.</li>
            <li><strong>Address proof:</strong> Required only if your current address is different from your Aadhaar card.</li>
            <li><strong>Caste certificate:</strong> Needed if you are applying under the Scheduled Caste (SC) or Scheduled Tribe (ST) category.</li>
          </ul>
        </section>
      </main>
    </div>
  </div>

  <section class="faq-section id-anchor" id="faq">
    <h2 class="faq-title">Frequently Asked Questions</h2>
    <div class="faq-container">
      {faqItems.map((item) => (
        <div class="faq-card">
          <div class="faq-question">
            <span>{item.question}</span>
            <svg class="faq-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
          <div class="faq-answer">
            <p>{item.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <script is:inline>
    const faqCards = document.querySelectorAll('.faq-card');
    faqCards.forEach((card) => {
      const question = card.querySelector('.faq-question');
      question?.addEventListener('click', () => {
        const isOpen = card.classList.contains('open');
        faqCards.forEach((faqCard) => faqCard.classList.remove('open'));
        if (!isOpen) {
          card.classList.add('open');
        }
      });
    });

    const sections = document.querySelectorAll('.section-anchor');
    const tocLinks = document.querySelectorAll('.toc-item-link');

    window.addEventListener('scroll', () => {
      let currentSectionId = '';
      sections.forEach((section) => {
        if (window.scrollY >= section.offsetTop - 120) {
          currentSectionId = section.getAttribute('id') ?? '';
        }
      });

      tocLinks.forEach((link) => {
        link.classList.remove('active');
        if (link.getAttribute('href') === `#${currentSectionId}`) {
          link.classList.add('active');
        }
      });
    });
  </script>
</SeoLayout>
