---
import SeoLayout from '../layouts/SeoLayout.astro';

export const prerender = true;
const pageTitle = 'Page Not Found | MeraLabh';
const pageDescription = 'The page you are looking for does not exist or has been moved. Explore MeraLabh scheme guides and tools.';
---
<SeoLayout
  title={pageTitle}
  description={pageDescription}
  noindex={true}
>
  <section class="hero-section" style="padding: 4rem 1.5rem; text-align: center;">
    <div class="hero-container" style="max-width: 600px; margin: 0 auto;">
      <h1 class="hero-title" style="font-size: 3rem; font-weight: 800; margin-bottom: 1rem;">404</h1>
      <h2 style="font-size: 1.5rem; color: #fff; margin-bottom: 1rem; font-weight: 600;">Page Not Found</h2>
      <p class="hero-description" style="margin-bottom: 2rem;">
        The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/" class="btn btn-primary" style="padding: 0.75rem 1.5rem;">Return to Homepage</a>
        <a href="/check/" class="btn btn-secondary" style="padding: 0.75rem 1.5rem;">Eligibility Tool</a>
        <a href="/schemes/" class="btn btn-secondary" style="padding: 0.75rem 1.5rem;">All Schemes</a>
      </div>
    </div>
  </section>
</SeoLayout>
